<!-- NexusRP — Écran de connexion (Microsoft uniquement) -->
<div id="loginOptionsContainer" style="display: none;">
    <div class="nexusAuthBackdrop"></div>
    <div class="nexusAuthCard" id="loginOptionsContent">
        <div class="nexusAuthBrand">
            <img class="nexusAuthLogo" src="assets/images/nexusrp-logo.svg" alt="NexusRP"/>
            <span class="nexusAuthBrandName">NexusRP</span>
        </div>
        <h2 class="nexusAuthTitle" id="loginOptionsTitle"><%- lang('loginOptions.loginOptionsTitle') %></h2>
        <p class="nexusAuthDesc" id="loginOptionsSubtitle"><%- lang('loginOptions.loginOptionsSubtitle') %></p>

        <div class="nexusAuthActions">
            <button id="loginOptionMicrosoft" class="nexusAuthMicrosoftBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 23 23">
                    <path fill="#f35325" d="M1 1h10v10H1z"/>
                    <path fill="#81bc06" d="M12 1h10v10H12z"/>
                    <path fill="#05a6f0" d="M1 12h10v10H1z"/>
                    <path fill="#ffba08" d="M12 12h10v10H12z"/>
                </svg>
                <span><%- lang('loginOptions.loginWithMicrosoft') %></span>
            </button>
        </div>

        <div id="loginOptionCancelContainer" style="display: none;">
            <button id="loginOptionCancelButton" class="nexusAuthSecondaryBtn"><%- lang('loginOptions.cancelButton') %></button>
        </div>
    </div>
    <script src="./assets/js/scripts/loginOptions.js"></script>
</div>
