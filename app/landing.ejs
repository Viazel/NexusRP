<!-- ═══════════════════════════════════════════════════════════════════════════
     NexusRP Launcher UI — Structure principale (sidebar + onglets)
     Les IDs hérités d'Helios sont conservés pour la compatibilité avec landing.js
     ═══════════════════════════════════════════════════════════════════════════ -->
<div id="landingContainer" style="display: none;">

    <div id="nexusShell">

        <!-- ── Sidebar gauche ─────────────────────────────────────────────── -->
        <aside id="nexusSidebar">
            <div id="nexusSidebarBrand">
                <img id="nexusLogo" src="assets/images/nexusrp-logo.svg" alt="NexusRP"/>
                <div id="nexusBrandText">
                    <span id="nexusBrandName">NexusRP</span>
                    <span id="nexusBrandTagline">Roleplay</span>
                </div>
            </div>

            <nav id="nexusNav">
                <button class="nexusNavItem active" data-tab="home" id="nexusNavHome">
                    <svg class="nexusNavIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/>
                        <path d="M9 21V12h6v9"/>
                    </svg>
                    <span>Nouvelle Terre</span>
                </button>
                <button class="nexusNavItem" data-tab="profile" id="nexusNavProfile">
                    <svg class="nexusNavIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    <span>Profil</span>
                </button>
                <button class="nexusNavItem" data-tab="settings" id="nexusNavSettings">
                    <svg class="nexusNavIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
                    </svg>
                    <span>Paramètres</span>
                </button>
            </nav>

            <div id="nexusSidebarFooter">
                <div id="nexusSocialLinks">
                    <a href="<%- lang('landing.mediaDiscordURL') %>" class="nexusSocialLink" id="discordURL" title="Discord">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.3 4.4A17.5 17.5 0 0 0 15.5 3a12 12 0 0 0-.6 1.2 16.2 16.2 0 0 0-4.8 0A11.6 11.6 0 0 0 9.5 3 17.4 17.4 0 0 0 4.7 4.4 18.5 18.5 0 0 0 1 16.4a17.7 17.7 0 0 0 5.4 2.7 13 13 0 0 0 1.2-2 8.5 8.5 0 0 1-1.9-.9l.5-.3a12.2 12.2 0 0 0 10.4 0l.5.3a8.6 8.6 0 0 1-1.9.9 13 13 0 0 0 1.2 2 17.6 17.6 0 0 0 5.4-2.7 18.4 18.4 0 0 0-3.7-12zM8.7 14.2c-1.1 0-2-.9-2-2.1s.9-2.1 2-2.1 2 1 2 2.1-.9 2.1-2 2.1zm6.6 0c-1.1 0-2-.9-2-2.1s.9-2.1 2-2.1 2 1 2 2.1-.9 2.1-2 2.1z"/></svg>
                    </a>
                </div>
            </div>
        </aside>

        <!-- ── Zone principale ──────────────────────────────────────────────── -->
        <main id="nexusMain">

            <!-- Onglet : Nouvelle Terre -->
            <section id="nexusTabHome" class="nexusTabPanel active">
                <div id="nexusHeroBg"></div>
                <div id="nexusHeroOverlay"></div>
                <div id="nexusHeroContent">
                    <div id="nexusHeroTop">
                        <div id="nexusHeroBadge">Serveur Principal</div>
                        <h1 id="nexusHeroTitle">Nouvelle Terre</h1>
                        <p id="nexusHeroSubtitle">Plongez dans l'univers roleplay de NexusRP</p>
                    </div>

                    <div id="nexusHeroBottom">
                        <!-- Statut serveur (IDs hérités Helios) -->
                        <div id="nexusServerCard" class="nexusGlassCard">
                            <div id="server_status_wrapper">
                                <div id="nexusServerStatusRow">
                                    <span id="nexusServerDot" class="nexusStatusDot"></span>
                                    <span class="bot_label" id="landingPlayerLabel"><%- lang('landing.serverStatus') %></span>
                                </div>
                                <span id="player_count" class="nexusServerCount"><%- lang('landing.serverStatusPlaceholder') %></span>
                            </div>
                            <span id="nexusServerAddress" class="nexusServerAddress">nouvelle-terre.fr</span>
                        </div>

                        <!-- Zone de lancement -->
                        <div id="nexusLaunchZone">
                            <div id="launch_content">
                                <button id="launch_button">
                                    <span id="launch_button_text">Se connecter à Nouvelle Terre</span>
                                    <svg class="nexusLaunchArrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                        <path d="M5 12h14M13 6l6 6-6 6"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Onglet : Profil -->
            <section id="nexusTabProfile" class="nexusTabPanel">
                <div class="nexusTabHeader">
                    <h2 class="nexusTabTitle">Mon Profil</h2>
                    <p class="nexusTabDesc">Vos informations en jeu sur NexusRP</p>
                </div>

                <div id="nexusProfileLayout">
                    <div id="nexusProfileAvatarCard" class="nexusGlassCard">
                        <div id="avatarContainer">
                            <button id="avatarOverlay"><%- lang('landing.usernameEditButton') %></button>
                        </div>
                        <span id="user_text" class="nexusProfileUsername"><%- lang('landing.usernamePlaceholder') %></span>
                    </div>

                    <div id="nexusProfileInfoCard" class="nexusGlassCard">
                        <!-- Données mock — à lier à votre API plus tard -->
                        <div class="nexusProfileField">
                            <span class="nexusProfileLabel">Nom en jeu</span>
                            <span class="nexusProfileValue" id="nexusProfileRpName">—</span>
                        </div>
                        <div class="nexusProfileField">
                            <span class="nexusProfileLabel">Portefeuille</span>
                            <span class="nexusProfileValue" id="nexusProfileWallet">0 $</span>
                        </div>
                        <div class="nexusProfileField">
                            <span class="nexusProfileLabel">Statut</span>
                            <span class="nexusProfileValue nexusProfileGrade" id="nexusProfileGrade">Citoyen</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Onglet : Paramètres -->
            <section id="nexusTabSettings" class="nexusTabPanel">
                <div class="nexusTabHeader">
                    <h2 class="nexusTabTitle">Paramètres</h2>
                    <p class="nexusTabDesc">Configuration du launcher</p>
                </div>

                <div id="nexusSettingsGrid">
                    <!-- Performances -->
                    <div class="nexusGlassCard nexusSettingsCard">
                        <h3 class="nexusCardTitle">Performances</h3>
                        <div class="nexusRamControl">
                            <div class="nexusRamHeader">
                                <span class="nexusProfileLabel">Allocation RAM</span>
                                <span id="nexusRamValue" class="nexusRamBadge">4 Go</span>
                            </div>
                            <input type="range" id="nexusRamSlider" class="nexusRamSlider" min="2" max="8" step="0.5" value="4"/>
                            <div class="nexusRamLabels">
                                <span>2 Go</span>
                                <span>8 Go</span>
                            </div>
                        </div>
                    </div>

                    <!-- Compte -->
                    <div class="nexusGlassCard nexusSettingsCard">
                        <h3 class="nexusCardTitle">Compte</h3>
                        <p class="nexusCardDesc">Gérez vos comptes Minecraft et Microsoft</p>
                        <button id="nexusOpenFullSettings" class="nexusSecondaryBtn">Gérer les comptes</button>
                    </div>

                    <!-- Dossiers -->
                    <div class="nexusGlassCard nexusSettingsCard">
                        <h3 class="nexusCardTitle">Dossiers</h3>
                        <div class="nexusProfileField">
                            <span class="nexusProfileLabel">Répertoire de données</span>
                            <span class="nexusProfileValue nexusPathValue" id="nexusDataPath">—</span>
                        </div>
                    </div>
                </div>
            </section>

        </main>
    </div>

    <!-- ── Barre de progression (bas de l'écran) ───────────────────────────── -->
    <div id="nexusProgressBar">
        <div id="launch_details">
            <div id="launch_details_left">
                <span id="launch_progress_label">0%</span>
            </div>
            <div id="launch_details_right">
                <div id="nexusProgressTrack">
                    <progress id="launch_progress" value="0" max="100"></progress>
                </div>
                <span id="launch_details_text" class="nexusProgressText"><%- lang('landing.launchDetails') %></span>
            </div>
        </div>
    </div>

    <!-- Élément caché conservé pour compatibilité JS Helios -->
    <div id="nexusCompatHidden" aria-hidden="true">
        <button id="server_selection_button" style="display:none"></button>
        <div id="image_seal_container">
            <img id="image_seal" src="assets/images/nexusrp-logo.svg"/>
            <div id="updateAvailableTooltip"><%- lang('landing.updateAvailableTooltip') %></div>
        </div>
        <div id="mojangStatusWrapper">
            <span id="mojang_status_icon">&#8226;</span>
            <div id="mojangStatusTooltip">
                <div id="mojangStatusTooltipTitle"><%- lang('landing.mojangStatusTooltipTitle') %></div>
                <div id="mojangStatusEssentialContainer"></div>
                <div id="mojangStatusNEContainer">
                    <div class="mojangStatusNEBar"></div>
                    <div id="mojangStatusNETitle"><%- lang('landing.mojangStatusNETitle') %></div>
                    <div class="mojangStatusNEBar"></div>
                </div>
                <div id="mojangStatusNonEssentialContainer"></div>
            </div>
        </div>
        <button id="settingsMediaButton"></button>
        <button id="newsButton">
            <div id="newsButtonAlert" style="display: none;"></div>
            <span id="newsButtonText"><%- lang('landing.newsButton') %></span>
        </button>
    </div>

    <!-- Panneau news (conservé pour la logique Helios) -->
    <div id="newsContainer">
        <div id="newsContent" article="-1" style="display: none;">
            <div id="newsStatusContainer">
                <div id="newsStatusContent">
                    <div id="newsTitleContainer">
                        <a id="newsArticleTitle" href="#">Lorem Ipsum</a>
                    </div>
                    <div id="newsMetaContainer">
                        <div id="newsArticleDateWrapper">
                            <span id="newsArticleDate">Mar 15, 44 BC</span>
                        </div>
                        <div id="newsArticleAuthorWrapper">
                            <span id="newsArticleAuthor">by Cicero</span>
                        </div>
                        <a href="#" id="newsArticleComments">0 Comments</a>
                    </div>
                </div>
                <div id="newsNavigationContainer">
                    <button id="newsNavigateLeft">
                        <svg id="newsNavigationLeftSVG" viewBox="0 0 24.87 13.97">
                            <polyline class="arrowLine" points="0.71 13.26 12.56 1.41 24.16 13.02"/>
                        </svg>
                    </button>
                    <span id="newsNavigationStatus"><%- lang('landing.newsNavigationStatus', { currentPage: 1, totalPages: 1 }) %></span>
                    <button id="newsNavigateRight">
                        <svg id="newsNavigationRightSVG" viewBox="0 0 24.87 13.97">
                            <polyline class="arrowLine" points="0.71 13.26 12.56 1.41 24.16 13.02"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div id="newsArticleContainer">
                <div id="newsArticleContent">
                    <div id="newsArticleContentScrollable"></div>
                </div>
            </div>
        </div>
        <div id="newsErrorContainer">
            <div id="newsErrorLoading">
                <span id="nELoadSpan" class="newsErrorContent"><%- lang('landing.newsErrorLoadSpan') %></span>
            </div>
            <div id="newsErrorFailed" style="display: none;">
                <span id="nEFailedSpan" class="newsErrorContent"><%- lang('landing.newsErrorFailedSpan') %></span>
                <button id="newsErrorRetry"><%- lang('landing.newsErrorRetryButton') %></button>
            </div>
            <div id="newsErrorNone" style="display: none;">
                <span id="nENoneSpan" class="newsErrorContent"><%- lang('landing.newsErrorNoneSpan') %></span>
            </div>
        </div>
    </div>

    <script src="./assets/js/scripts/nexusrp-ui.js"></script>
    <script src="./assets/js/scripts/landing.js"></script>
</div>
