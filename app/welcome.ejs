<!-- NexusRP — Écran de bienvenue (première ouverture) -->
<div id="welcomeContainer" style="display: none;">
    <div class="nexusAuthBackdrop"></div>
    <div class="nexusAuthCard" id="welcomeContent">
        <div class="nexusAuthBrand">
            <img id="welcomeImageSeal" src="assets/images/nexusrp-logo.svg" alt="NexusRP"/>
            <span class="nexusAuthBrandName">NexusRP</span>
        </div>
        <span id="welcomeHeader" class="nexusAuthTitle"><%- lang('welcome.welcomeHeader') %></span>
        <span id="welcomeDescription" class="nexusAuthDesc"><%- lang('welcome.welcomeDescription') %></span>
        <span id="welcomeDescCTA" class="nexusAuthCta"><%- lang('welcome.welcomeDescCTA') %></span>
        <button id="welcomeButton" class="nexusAuthPrimaryBtn">
            <%- lang('welcome.continueButton') %>
            <svg class="nexusAuthBtnArrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
        </button>
    </div>
    <script src="./assets/js/scripts/welcome.js"></script>
</div>
